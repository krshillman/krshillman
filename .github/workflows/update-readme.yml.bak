name: Update README

on:
  schedule:
    - cron: "0 0 * * *"   # daily at midnight UTC
  workflow_dispatch:        # allow manual trigger from Actions tab
  push:
    branches:
      - main

jobs:

  # ─── 1. Generate metrics SVG (commits, PRs reviewed, stars, etc.) ───────────
  metrics:
    name: Render github-metrics.svg
    runs-on: ubuntu-latest
    permissions:
      contents: write
    steps:
      - uses: lowlighter/metrics@latest
        with:
          token: ${{ secrets.METRICS_TOKEN }}
          filename: github-metrics.svg

          # Base sections to include
          base: header, activity, community, repositories, metadata

          # Show commits, PRs, reviews, issues
          base_indepth: yes

          # ── Plugins ──────────────────────────────────────────────────────────

          # Isometric contribution calendar (great visual)
          plugin_isocalendar: yes
          plugin_isocalendar_duration: full-year

          # Code habits (commit times, languages)
          plugin_habits: yes
          plugin_habits_from: 200
          plugin_habits_days: 14
          plugin_habits_facts: yes
          plugin_habits_charts: yes

          # Most-used languages
          plugin_languages: yes
          plugin_languages_indepth: yes
          plugin_languages_details: lines, percentage
          plugin_languages_limit: 8

          # Recent activity (pushes, PRs, reviews)
          plugin_activity: yes
          plugin_activity_limit: 5
          plugin_activity_days: 14
          plugin_activity_filter: push, pr, review, issue

          # ── Theme ────────────────────────────────────────────────────────────
          config_theme: default
          config_timezone: Australia/Melbourne

  # ─── 2. Pull latest blog posts from Ghost in the Data RSS feed ──────────────
  #blog-posts:
  #  name: Sync blog posts to README
  #  runs-on: ubuntu-latest
  #  permissions:
  #    contents: write
  #  steps:
  #    - uses: actions/checkout@v4
  #    - uses: gautamkrishnar/blog-post-workflow@v1
  #      with:
  #        feed_list: "https://ghostinthedata.info/index.xml"
  #        max_post_count: 5
  #        readme_path: README.md
  #        comment_tag_name: BLOG-POST-LIST
  #        gh_token: ${{ secrets.METRICS_TOKEN }}

  # ─── 3. Recent GitHub activity (pushes, PRs, code reviews) ─────────────────
  activity:
    name: Sync recent activity to README
    runs-on: ubuntu-latest
    permissions:
      contents: write
    steps:
      - uses: actions/checkout@v4
      - uses: jamesgeorge007/github-activity-readme@master
        env:
          GITHUB_TOKEN: ${{ secrets.METRICS_TOKEN }}
        with:
          COMMIT_MSG: "chore: update recent activity"
          MAX_LINES: 10
